{
	"semi": true,
	"singleQuote": true,
	"printWidth": 100,
	"tabWidth": 2,
	"trailingComma": "none",
	"useTabs": true,
	"plugins": ["prettier-plugin-svelte"],
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		}
	],

	"language": "postgresql",
	"keywordCase": "upper"
}
